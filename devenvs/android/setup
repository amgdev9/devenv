#!/bin/bash
su - amgdev -c "command -v adb" &>/dev/null && exit 0

cd "$(dirname "$0")"
apt-get install -y unzip openjdk-21-jdk
KOTLIN_LSP_VERSION=$(curl -s https://api.github.com/repos/Kotlin/kotlin-lsp/releases/latest | grep -Po '"name"\s*:\s*"v\K[^"]*')
su - amgdev <<'EOF'
    curl -o kotlinlsp.tar.gz https://download-cdn.jetbrains.com/kotlin-lsp/${KOTLIN_LSP_VERSION}/kotlin-server-${KOTLIN_LSP_VERSION}.tar.gz
    mkdir .kotlin-lsp
    tar -xzf kotlinlsp.tar.gz -C .kotlin-lsp 
    rm kotlinlsp.tar.gz
    chmod u+x .kotlin-lsp/kotlin-server-${KOTLIN_LSP_VERSION}/bin/intellij-server
    mv .kotlin-lsp/kotlin-server-${KOTLIN_LSP_VERSION}/bin/intellij-server .kotlin-lsp/kotlin-server-${KOTLIN_LSP_VERSION}/bin/kotlin-lsp
    echo 'export PATH=$PATH:$HOME/.kotlin-lsp/kotlin-server-${KOTLIN_LSP_VERSION}/bin' >> ~/.bashrc

    curl -o cmdtools.zip https://dl.google.com/android/repository/commandlinetools-linux-14742923_latest.zip
    unzip cmdtools.zip 
    rm cmdtools.zip 
    mkdir -p ~/android-sdk/cmdline-tools
    mv cmdline-tools ~/android-sdk/cmdline-tools/latest

    echo "" >> ~/.bashrc
    echo "# Android SDK Configuration" >> ~/.bashrc
    echo 'export ANDROID_HOME=$HOME/android-sdk' >> ~/.bashrc
    echo 'export PATH=$PATH:$ANDROID_HOME/cmdline-tools/latest/bin' >> ~/.bashrc
    echo 'export PATH=$PATH:$ANDROID_HOME/platform-tools' >> ~/.bashrc
    
    yes | ~/android-sdk/cmdline-tools/latest/bin/sdkmanager --licenses
    ~/android-sdk/cmdline-tools/latest/bin/sdkmanager "platform-tools"

    curl https://dl.google.com/android/cli/latest/linux_x86_64/android --output android
    chmod u+x android
    mv android ~/android-sdk/cmdline-tools/latest/bin  
EOF
cp lsp.lua /home/amgdev/.config/nvim-code/lua/custom/kotlin.lua 
chown amgdev:amgdev /home/amgdev/.config/nvim-code/lua/custom/kotlin.lua 
cp debug.lua /home/amgdev/.config/nvim-debugger/lua/custom/android.lua
chown amgdev:amgdev /home/amgdev/.config/nvim-debugger/lua/custom/android.lua

